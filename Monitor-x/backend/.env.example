# Server port
PORT=5000

# Local MongoDB (install: winget install MongoDB.Server)
MONGODB_URI=mongodb://127.0.0.1:27017/transport_tms
# Or MongoDB Atlas free tier:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/transport_tms

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=change-me

# Frontend dev origins allowed by CORS. Include both loopback hostnames so the
# admin app works whether it is opened through localhost or 127.0.0.1.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# SMS / OTP delivery. Keep `dev` during local UI development; it writes the OTP
# only to the backend console. Set to `fast2sms` to deliver real OTP messages.
SMS_PROVIDER=dev

# Fast2SMS API key. Put the real value only in backend/.env, never in this
# tracked example file or in a frontend VITE_* variable.
FAST2SMS_API_KEY=

# Automatic trip scheduling. Pickup trips reach the office this many minutes
# before login; drivers are asked to report this many minutes before departure.
SCHEDULE_ARRIVAL_BUFFER_MINUTES=5
SCHEDULE_DRIVER_BUFFER_MINUTES=5
SCHEDULE_STOP_DWELL_MINUTES=2

# GPS ETA recalculation is throttled, and employees are notified only when the
# predicted time changes by at least this threshold.
LIVE_ETA_THROTTLE_MS=30000
LIVE_ETA_NOTIFY_SECONDS=120

# Optional. When set, schedules and live GPS ETAs use Google Routes traffic;
# without it, MonitorX uses the deterministic time-of-day traffic fallback.
GOOGLE_ROUTES_API_KEY=

# Route-corridor matching. Public OSRM is suitable for local testing; production
# should use a managed/self-hosted routing endpoint with the same API shape.
OSRM_BASE_URL=https://router.project-osrm.org
ROUTE_CORRIDOR_MAX_METERS=2000
ROUTE_AMBIGUITY_METERS=250
